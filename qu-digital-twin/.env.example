# Copy this file to .env and fill in the key for whichever provider you use.
# LLM_PROVIDER controls which backend agent.py talks to: "groq" (default, free),
# "anthropic", or "openai".

LLM_PROVIDER=groq

# Groq — free tier, no credit card required. Get a key at https://console.groq.com/keys
# Default model: llama-3.3-70b-versatile (supports tool calling, which is all this
# agent needs). Override with LLM_MODEL if you want a different Groq model.
GROQ_API_KEY=

# Only needed if you set LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Only needed if you set LLM_PROVIDER=openai
OPENAI_API_KEY=

# Optional: override the default model for whichever provider you picked above.
# LLM_MODEL=llama-3.3-70b-versatile
